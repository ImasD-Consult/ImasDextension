# Copy to .env and adjust. Required for production builds when the extension is hosted on a
# different origin than Trimble Connect (e.g. extensions.imasd.dev): API calls must target the
# same regional "shard" as the project in your browser or you get empty/404 responses (CORS or wrong DC).
#
# Match the host in your Trimble Connect tab:
#   North America:  https://app.connect.trimble.com
#   Europe:         https://app21.connect.trimble.com
#   Asia / Pacific: https://app31.connect.trimble.com
#
# Restart `pnpm dev` after changing. For Docker/CI, set the same value at build time
# (see Dockerfile ARG VITE_TRIMBLE_CONNECT_ORIGIN and GitHub Actions variable).

VITE_TRIMBLE_CONNECT_ORIGIN=https://app21.connect.trimble.com
