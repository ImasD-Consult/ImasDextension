# Copy to .env and adjust. API calls must target the same regional "shard" as your Trimble Connect
# tab (wrong region ⇒ empty/404). CORS may still block cross-origin fetch from the extension host;
# the Viewer API path in code avoids that when the IFC is open in 3D.
#
# Match the host in your Trimble Connect tab:
#   North America:  https://app.connect.trimble.com
#   Europe:         https://app21.connect.trimble.com
#   Asia / Pacific: https://app31.connect.trimble.com
#
# Local dev: restart `pnpm dev` after changing (Vite bakes VITE_* at dev/build time).
#
# Docker image (serve): you do NOT need to rebuild to change region — set either variable on the
# container; docker-entrypoint.sh writes public env.js with:
#   TRIMBLE_CONNECT_ORIGIN  (preferred name at runtime), or
#   VITE_TRIMBLE_CONNECT_ORIGIN
# Example compose:
#   environment:
#     TRIMBLE_CONNECT_ORIGIN: "https://app21.connect.trimble.com"
#
# CI image build: still pass VITE_TRIMBLE_CONNECT_ORIGIN as Docker build-arg / GitHub Actions var
# if you want a default baked into the bundle as well.
#
# Two Trimble manifests (same build): `manifest.json` → Project → Extensions only;
# `manifest-3d.json` → 3D Viewer → Extensions only (same `url`, no duplicate menus).

VITE_TRIMBLE_CONNECT_ORIGIN=https://app21.connect.trimble.com

# Optional: explicit QR target URL template (recommended for production).
# Placeholders supported:
#   {origin} {modelId} {modelVersionId} {partId} {partLink}
# Example (replace with your final Trimble-compatible target pattern):
# TRIMBLE_CONNECT_QR_URL_TEMPLATE={origin}/?modelId={modelId}&objectId={partId}
TRIMBLE_CONNECT_QR_URL_TEMPLATE=
